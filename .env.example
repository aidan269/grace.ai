# Grace env template
# Copy to `.env.local` for local use, or set these in Vercel Project Settings.

# Required: Anthropic API access for Grace generation/triage flows.
ANTHROPIC_API_KEY=

# Required for GitHub issue/queue + push/share APIs.
GITHUB_TOKEN=

# Required for Supabase-backed intel/audit storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Brave Search fallback for URL content enrichment.
BRAVE_API_KEY=

# Optional: Slack integration for feed posting + plugin inactivity nudges.
SLACK_WEBHOOK_URL=
SLACK_FEED_TOP_N=8

# Optional: Feature toggles for background posting behavior.
SLACK_ON_NEWS_SYNC=true
SLACK_ON_INTAKE=false

# Optional: Repo defaults used by intake/queue flows.
NEWS_QUEUE_REPO_OWNER=aidan269
NEWS_QUEUE_REPO=grace.ai

# Optional: endpoint protection secrets.
CRON_SECRET=
HEALTH_SECRET=

# Grace Ops model ensemble (optional for multi-model adjudication).
OPENAI_API_KEY=
GEMINI_API_KEY=
